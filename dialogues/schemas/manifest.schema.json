{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/manifest.schema.json",
  "title": "Manifesto da ferramenta de estudo de diálogos",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "targetLanguage",
    "supportLanguage",
    "categories"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "targetLanguage": {
      "$ref": "#/$defs/languageTag"
    },
    "supportLanguage": {
      "$ref": "#/$defs/languageTag"
    },
    "categories": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/categoryEntry"
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "languageTag": {
      "type": "string",
      "pattern": "^[a-z]{2,3}(?:-[A-Z][a-z]{3})?(?:-[A-Z]{2}|-[0-9]{3})?$"
    },
    "nonEmptyText": {
      "type": "string",
      "minLength": 1
    },
    "categoryEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "dataFile",
        "practiceRole",
        "dialogueCount"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "title": {
          "$ref": "#/$defs/nonEmptyText"
        },
        "description": {
          "$ref": "#/$defs/nonEmptyText"
        },
        "dataFile": {
          "type": "string",
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?![a-zA-Z][a-zA-Z0-9+.-]*:).+\\.json$"
        },
        "practiceRole": {
          "$ref": "#/$defs/identifier"
        },
        "dialogueCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
